import { entreprises } from "./entreprises.js"; // ton tableau d'entreprises
import { sauvegarder } from "./sauvegarde.js";   // si tu as un module de sauvegarde

// ID entreprise (temporaire)
const id = 0;

// Sélecteurs
const nomInput = document.getElementById("nom");
const discordInput = document.getElementById("discord");
const descriptionInput = document.getElementById("description");

const posteInput = document.getElementById("poste");
const listePostesEl = document.getElementById("liste-postes");

const btnSaveIdentite = document.getElementById("btn-save-identite");
const btnAddPoste = document.getElementById("btn-add-poste");

// Chargement initial des données
function chargerEntreprise() {
  const e = entreprises[id];

  nomInput.value = e.nom || "";
  discordInput.value = e.discord || "";
  descriptionInput.value = e.description || "";

  afficherPostes();
}

// Afficher les postes
function afficherPostes() {
  const e = entreprises[id];

  listePostesEl.innerHTML = "";

  if (!e.postes || e.postes.length === 0) {
    listePostesEl.innerHTML = "<p>Aucun poste pour le moment.</p>";
    return;
  }

  e.postes.forEach((p, index) => {
    const div = document.createElement("div");
    div.className = "poste-item";
    div.textContent = `• ${p}`;

    // bouton supprimer
    const btnDel = document.createElement("button");
    btnDel.textContent = "X";
    btnDel.className = "btn-del";
    btnDel.onclick = () => {
      e.postes.splice(index, 1);
      sauvegarder?.();
      afficherPostes();
    };

    div.appendChild(btnDel);
    listePostesEl.appendChild(div);
  });
}

// Sauvegarde identité
btnSaveIdentite.onclick = () => {
  const e = entreprises[id];

  e.nom = nomInput.value;
  e.discord = discordInput.value;
  e.description = descriptionInput.value;

  sauvegarder?.();

  alert("Identité enregistrée !");
};

// Ajouter un poste
btnAddPoste.onclick = () => {
  const e = entreprises[id];
  const poste = posteInput.value.trim();

  if (poste === "") {
    alert("Le poste ne peut pas être vide.");
    return;
  }

  if (!e.postes) e.postes = [];

  e.postes.push(poste);
  posteInput.value = "";

  sauvegarder?.();
  afficherPostes();
};

// Lancement
chargerEntreprise();
